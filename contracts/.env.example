# Copy to contracts/.env — used by forge deploy scripts (never commit real keys)

# Cast keystore account (from `cast wallet list` / `npm run cast:address`)
DEPLOY_ACCOUNT=deployMeta
# Optional: avoid password prompt during deploy
# FOUNDRY_PASSWORD=
# ETH_PASSWORD=

# Server signer address (must match SIGNER_PRIVATE_KEY on EC2 / server/.env)
SIGNER_ADDRESS=0x0000000000000000000000000000000000000000

# Treasury — receives USDC bot-create and tier fees
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# Optional overrides (defaults set per network in deploy-agentic-arena.js)
# USDC_ADDRESS=0x036CbD53842c6846630281C1C3aD1868e8e7a34f   # Base Sepolia
# USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913   # Base mainnet
# SETTLEMENT_SIGNER=   # defaults to SIGNER_ADDRESS

# RPC (repo root .env is also loaded)
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# BASE_RPC_URL=https://mainnet.base.org

# Basescan verification (optional): VERIFY=1 node scripts/deploy-agentic-arena.js base-sepolia
# BASESCAN_API_KEY=
