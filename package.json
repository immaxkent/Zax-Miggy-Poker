{
  "name": "cryptopoker",
  "version": "1.0.1",
  "private": true,
  "description": "CryptoPoker — on-chain poker on Base",
  "scripts": {
    "open-ssh": "ssh -i ~/Downloads/poker-game-server.pem ubuntu@35.179.163.69",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "start:server": "cd server && npm start",
    "test:contracts": "cd contracts && forge test",
    "test:arena": "cd contracts && forge test --match-contract 'AgenticArena|AgenticChips1155|AgenticRankingsV2|BotFactory|AgenticArenaTypes'",
    "test:server": "cd server && npm test",
    "test": "npm run test:contracts && npm run test:server",
    "test:e2e": "cd e2e && npm test",
    "test:e2e:arena": "cd e2e && npm run test:arena",
    "test:smoke:sepolia": "cd e2e && npm run test:smoke:sepolia",
    "cast:list": "cast wallet list",
    "cast:address": "node scripts/cast-wallet-address.js",
    "deploy:base-sepolia": "node scripts/deploy-agentic-arena.js base-sepolia",
    "deploy:base-mainnet": "node scripts/deploy-agentic-arena.js base",
    "wire:base-sepolia": "node scripts/wire-agentic-env.js base-sepolia",
    "wire:base-mainnet": "node scripts/wire-agentic-env.js base",
    "wire:base-sepolia:ec2": "node scripts/wire-ec2-arena-env.js base-sepolia",
    "wire:base-mainnet:ec2": "node scripts/wire-ec2-arena-env.js base",
    "deploy:vault:base": "cd contracts && forge script script/DeployZaxMiggyBase.s.sol:DeployZaxMiggyBase --rpc-url ${BASE_RPC_URL:-https://mainnet.base.org} --broadcast --account ${DEPLOY_ACCOUNT:-deployMeta}",
    "deploy:arena:base-sepolia": "npm run deploy:base-sepolia",
    "deploy:arena:base": "npm run deploy:base-mainnet",
    "wire:arena:base-sepolia": "npm run wire:base-sepolia",
    "wire:arena:base": "npm run wire:base-mainnet",
    "wire:arena:ec2-sepolia": "npm run wire:base-sepolia:ec2",
    "wire:arena:ec2-base": "npm run wire:base-mainnet:ec2",
    "extract:base": "node scripts/extract-and-save.js base 1.0.1",
    "redeploy": "node scripts/redeploy.js",
    "sim": "cd e2e && node bot-sim.js"
  }
}
